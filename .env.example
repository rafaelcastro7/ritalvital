# Supabase — crea un proyecto en https://supabase.com y copia los valores desde Project Settings > API
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# URL del backend Python (pipeline.py corriendo con uvicorn / FastAPI)
# Desarrollo local: http://localhost:8000
# Producción: URL de tu servidor o Railway/Render deployment
VITE_BACKEND_URL=http://localhost:8000
